#!/bin/sh
# preinit - set up overlayfs writable root before /sbin/init
# Boot with: init=/sbin/preinit
#
# Creates a tmpfs-backed overlayfs over the read-only cramfs rootfs.
# The tmpfs backing store (/tmp) is NOT moved into the overlay — the
# overlay holds VFS references to the upper/work dirs, so they survive
# switch_root even though /tmp becomes invisible in the new namespace.
# Writes to /tmp in the running system go through the overlay upper layer.

mount -t proc proc /proc
mount -t devtmpfs devtmpfs /dev 2>/dev/null

# tmpfs for overlay backing store (upper + work + mountpoint)
mount -t tmpfs -o size=4m tmpfs /tmp
mkdir -p /tmp/upper /tmp/work /tmp/newroot

# Mount overlay: read-only cramfs below, writable tmpfs above
if ! mount -t overlay overlay \
    -o "lowerdir=/,upperdir=/tmp/upper,workdir=/tmp/work" \
    /tmp/newroot; then
    echo "preinit: overlay mount failed, booting read-only"
    umount /tmp /dev /proc 2>/dev/null
    exec /sbin/init "$@"
fi

# Move kernel-mounted filesystems into the overlay
mount --move /proc /tmp/newroot/proc
mount --move /dev /tmp/newroot/dev

echo "preinit: switching to overlayfs root"
exec chroot /tmp/newroot /sbin/init "$@"
